{
  "mcpServers": {
    "project-files": {
      "command": "python",
      "args": [
        "-m",
        "project_assistant_mcp.server"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "ASSISTANT_PROJECT_ROOT": "${env:ASSISTANT_PROJECT_ROOT}",
        "ASSISTANT_LOG_DIR": "${env:ASSISTANT_LOG_DIR}",
        "ASSISTANT_MAX_FILE_BYTES": "${env:ASSISTANT_MAX_FILE_BYTES}"
      },
      "toolFilter": {
        "mode": "exclude",
        "tools": [
          "write_file",
          "replace_in_file"
        ]
      }
    }
  }
}
