ASSISTANT_PROJECT_ROOT=.
ASSISTANT_OLLAMA_BASE_URL=http://127.0.0.1:11434
ASSISTANT_OLLAMA_MODEL=qwen3:8b
ASSISTANT_MAX_ITERATIONS=3
ASSISTANT_EMBEDDINGS_MODEL=embeddinggemma
ASSISTANT_BRIDGE_HOST=127.0.0.1
ASSISTANT_BRIDGE_PORT=8000
ASSISTANT_MCP_BRIDGE_URL=http://127.0.0.1:8000
ASSISTANT_BRIDGE_CONFIG_PATH=.project-assistant/ollama-mcp-bridge.json
ASSISTANT_LOG_DIR=logs
ASSISTANT_MAX_FILE_BYTES=1000000
ASSISTANT_REQUEST_TIMEOUT_SECONDS=120
ASSISTANT_ALLOWED_GLOBS=*.py,*.md,*.toml,*.json,*.yaml,*.yml,*.txt
